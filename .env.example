# ── Required ──────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ── LLM configuration ─────────────────────────────────────────────────────────
# Separate key for the comparative reasoning stage.
# Defaults to MISTRAL_API_KEY when left empty.
MISTRAL_COMPARATIVE_API_KEY=

# Model used by explainer_agent and comparative_reasoner.
# Default: mistral-small-latest
MISTRAL_EXPLAINER_MODEL=

# Sampling temperature for LLM explanation calls.
# Default: 0.2
EXPLAINER_TEMPERATURE=

# ── Explainer behaviour ────────────────────────────────────────────────────────
# Set to 1 to disable adversity-seeded reasoning injection.
# Default: 0 (seeds enabled)
EXPLAINER_SEEDS_DISABLED=

# Tag appended to log filenames, useful for labelling experiment runs.
# Default: (empty — no tag)
EXPLAINER_RUN_TAG=

# Set to 0 to skip the comparative reasoning paragraph entirely.
# Default: 1 (enabled)
EXPLAINER_COMPARATIVE_STAGE_ENABLED=

# ── Engine / minimax ──────────────────────────────────────────────────────────
# Set to false to bypass minimax scoring (debugging only).
# Default: true
MINIMAX_ENABLED=

# Negamax search depth.
# Default: 6
MINIMAX_DEPTH=

# Piece-square penalty applied to caged kings during board evaluation.
# Default: 75
CAGED_KING_PENALTY=

# Enable quiescence capture extension at search leaves.
# Default: true
QUIESCENCE_CAPTURE_EXTENSION_ENABLED=

# Maximum extra plies explored during quiescence capture extension.
# Default: 4
QUIESCENCE_MAX_CAPTURE_PLIES=

# ── Selective D8 extension ────────────────────────────────────────────────────
# Set to true to re-search promising tactical positions at depth 8.
# Default: false
SELECTIVE_D8_ENABLED=

# Minimum piece count (total pieces on board) to allow D8 extension.
# Default: 14
SELECTIVE_D8_PIECE_THRESHOLD=

# Minimum minimax gap (best minus second-best score) to trigger D8 extension.
# Default: 30
SELECTIVE_D8_GAP_THRESHOLD=

# Depth used during the D8 re-search pass.
# Default: 8
SELECTIVE_D8_DEPTH=

# Include moves whose minimax score equals the best when selecting D8 candidates.
# Default: false
SELECTIVE_D8_INCLUDE_EXACT_TIES=

# Enable promotion-race verification within the D8 pass.
# Default: true
PROMOTION_RACE_VERIFY_ENABLED=

# Piece-count threshold below which promotion-race verification is active.
# Default: 14
PROMOTION_RACE_PIECE_THRESHOLD=

# Depth used for promotion-race verification search.
# Default: 10
PROMOTION_RACE_VERIFY_DEPTH=

# Score margin (centipawn equivalent) for promotion-race verification.
# Default: 15.0
PROMOTION_RACE_VERIFY_MARGIN=

# ── Evaluation ────────────────────────────────────────────────────────────────
# Score difference below which two candidate scores are treated as equal
# during claim verification.
# Default: 0.5
SCORE_GAP_EPSILON=

# ── Logging ───────────────────────────────────────────────────────────────────
# Print per-turn summary to stdout via logger_node.
# Default: true
CHECKERS_LOGGER_PRINT=

# Directory for JSONL game logs.
# Default: logs
CHECKERS_LOG_DIR=

# ── Baseline evaluation (checkers/baseline_eval/ scripts only) ────────────────
# API key for the LLM-only baseline agent. Defaults to MISTRAL_API_KEY.
BASELINE_MISTRAL_API_KEY=

# Model used by the baseline agent.
# Default: mistral-large-latest
BASELINE_MISTRAL_MODEL=

# Sampling temperature for baseline agent calls.
# Default: 0.2
BASELINE_MISTRAL_TEMPERATURE=

# Max tokens for baseline agent responses.
# Default: 1200
BASELINE_MISTRAL_MAX_TOKENS=

# ── KingsRow benchmark (run_kingsrow_benchmark_trace.py only) ─────────────────
# Full path to the KingsRow shared library (.dll on Windows, .so on Linux).
# Only required when running the KingsRow benchmark script.
# Example (Linux): /usr/local/lib/libkingsrow.so
KINGSROW_DLL_PATH=
